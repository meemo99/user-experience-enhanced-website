    <ul>
                {% for district in districts%}
                    
                    
                        <li><a href="/district/{{ district }}" class="district-nav district-{{ story.district }}">{{ district |capitalize }}</a></li>
                    
                {% endfor %}
                <li><a href="/archief" class="district-nav">Archief</a></li>
                </ul>
            
     </nav>
    </header>

    

<section class="art-container">
  {% for story in district %}
    <article class="index-article district-{{ story.district }}">
      {% if story.cover %}
  <img 
    src="https://fdnd-agency.directus.app/assets/{{ story.cover }}"   
    width="{{cover.width}}"
    alt="{{ story.title }}"
    class="cover">
{% endif %}
      <div class="tags">
        <span class="district-tag">{{ story.district | capitalize }}</span>
        <span class="district-tag">{{ story.target_group |capitalize }}</span>
      </div>
      <h2>{{ story.title }}</h2>
      <p>{{ story.intro }}</p>
      <a href="/story/{{ story.slug }}" class="leesmeer district-tag">Lees meer</a>
    </article>
  {% endfor %}
</section>

{% render 'partials/foot.liquid' %}
