    <ul>
                {% for district in districts%}
                    
                    
                        <li><a href="/district/{{ district }}" class="district-nav district-{{ story.district }}">{{ district |capitalize }}</a></li>
                    
                {% endfor %}
                <li><a href="/archief" class="district-nav">Archief</a></li>
                </ul>
            
     </nav>
    </header>


<!-- Target group filter -->
<section class="filters">
  <a href="/archief?year={{ activeYear }}" 
    class="filter-btn {% if activeGroup == '' %}active{% endif %}">
    Alle Doelgroepen
  </a>
  {% for group in targetGroups %}
    <a href="/archief?target_group={{ group }}&year={{ activeYear }}" 
      class="filter-btn {% if activeGroup == group %}active{% endif %}">
      {{ group | capitalize }}
    </a>
  {% endfor %}
</section>

<!-- Year filter -->
<section class="filters">
  <a href="/archief?target_group={{ activeGroup }}" 
    class="filter-btn {% if activeYear == '' %}active{% endif %}">
    Alle jaren
  </a>
  {% for year in years %}
    <a href="/archief?target_group={{ activeGroup }}&year={{ year }}" 
      class="filter-btn {% if activeYear == year %}active{% endif %}">
      {{ year }}
    </a>
  {% endfor %}
</section>

<main>
  <h1>Archief 
    {% if activeGroup %}— {{ activeGroup | capitalize }}{% endif %}
    {% if activeYear %}— {{ activeYear }}{% endif %}
  </h1>

  {% assign currentYear = '' %}
  {% for story in stories %}
    {% assign storyYear = story.date | slice: 0, 4 %}

    {% if storyYear != currentYear %}
      {% assign currentYear = storyYear %}
      <h2 class="archive-year">{{ storyYear }}</h2>
    {% endif %}

    <article class="archive-item district-{{ story.district }}">
      <div class="archive-meta">
        <span class="district-tag">{{ story.district | capitalize }}</span>
        <span class="district-tag">{{ story.target_group | capitalize }}</span>
        <time>{{ story.date | slice: 0, 10 }}</time>
      </div>
      <a href="/story/{{ story.slug }}">
        <h3>{{ story.title }}</h3>
      </a>
      <p>{{ story.intro }}</p>
    </article>
  {% endfor %}

  {% if stories.size == 0 %}
    <p>Geen artikelen gevonden.</p>
  {% endif %}
</main>
{% render 'partials/foot.liquid' %}